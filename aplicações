<!DOCTYPE html>
<html lang="pt-br">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Everton Francisco – Correspondente Bancário</title>
<link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@400;600;700;800;900&family=Lato:wght@300;400;700&display=swap" rel="stylesheet">
<style>
  :root{--azul:#1e3a6e;--azul-medio:#2d5299;--azul-claro:#3b6cc5;--laranja:#e07b39;--laranja2:#f0924a;}
  *,*::before,*::after{box-sizing:border-box;margin:0;padding:0;}
  body{font-family:'Lato',sans-serif;background:#f0f4fb;min-height:100vh;overflow-x:hidden;}
  #home{min-height:100vh;display:flex;flex-direction:column;align-items:center;justify-content:center;padding:40px 20px;background:linear-gradient(160deg,#eef3fb 0%,#d8e8f8 100%);position:relative;overflow:hidden;}
  #home::before{content:'';position:absolute;top:-100px;right:-120px;width:420px;height:420px;border-radius:50%;background:radial-gradient(circle,rgba(30,58,110,0.07) 0%,transparent 70%);}
  #home::after{content:'';position:absolute;bottom:-80px;left:-60px;width:340px;height:340px;border-radius:50%;background:radial-gradient(circle,rgba(224,123,57,0.09) 0%,transparent 70%);}
  .hero{text-align:center;margin-bottom:44px;position:relative;z-index:1;animation:fadeDown 0.55s ease both;}
  @keyframes fadeDown{from{opacity:0;transform:translateY(-18px)}to{opacity:1;transform:translateY(0)}}
  .hero-card{background:white;border-radius:16px;box-shadow:0 6px 32px rgba(30,58,110,0.14);display:inline-flex;align-items:center;overflow:hidden;margin-bottom:32px;max-width:700px;width:100%;}
  .hero-card-left{padding:16px 20px;display:flex;align-items:center;justify-content:center;flex-shrink:0;}
  .hero-card-left img{height:56px;display:block;}
  .hero-card-right{background:var(--azul-medio);flex:1;padding:16px 22px;display:flex;flex-direction:column;justify-content:center;gap:6px;min-height:88px;}
  .contact-item{display:flex;align-items:center;gap:8px;color:rgba(255,255,255,0.85);font-size:0.78rem;font-family:'Montserrat',sans-serif;font-weight:500;}
  .hero h1{font-family:'Montserrat',sans-serif;font-size:clamp(1.6rem,5vw,2.5rem);font-weight:900;color:var(--azul);line-height:1.2;letter-spacing:-0.5px;margin-bottom:10px;}
  .hero h1 .destaque{color:var(--laranja);}
  .hero p{font-size:1rem;color:#5a6a85;max-width:440px;margin:0 auto;line-height:1.6;}
  .menu-grid{display:grid;grid-template-columns:repeat(5,1fr);gap:14px;max-width:1100px;width:100%;position:relative;z-index:1;}
  .menu-card{background:white;border-radius:18px;box-shadow:0 4px 20px rgba(30,58,110,0.09);padding:26px 22px;cursor:pointer;border:2px solid transparent;transition:transform 0.2s,box-shadow 0.2s,border-color 0.2s;display:flex;flex-direction:column;align-items:center;text-align:center;gap:12px;animation:fadeUp 0.55s ease both;}
  .menu-card:nth-child(1){animation-delay:.1s}.menu-card:nth-child(2){animation-delay:.2s}.menu-card:nth-child(3){animation-delay:.3s}.menu-card:nth-child(4){animation-delay:.4s}.menu-card:nth-child(5){animation-delay:.5s}
  @keyframes fadeUp{from{opacity:0;transform:translateY(22px)}to{opacity:1;transform:translateY(0)}}
  .menu-card:hover{transform:translateY(-4px);box-shadow:0 10px 32px rgba(30,58,110,0.16);border-color:var(--azul-claro);}
  .menu-card:active{transform:scale(0.97);}
  .card-icon{width:56px;height:56px;border-radius:14px;display:flex;align-items:center;justify-content:center;font-size:24px;background:linear-gradient(135deg,var(--azul) 0%,var(--azul-claro) 100%);color:white;box-shadow:0 4px 14px rgba(30,58,110,0.25);flex-shrink:0;}
  .card-icon.laranja{background:linear-gradient(135deg,var(--laranja) 0%,var(--laranja2) 100%);box-shadow:0 4px 14px rgba(224,123,57,0.3);}
  .menu-card h3{font-family:'Montserrat',sans-serif;font-size:0.92rem;font-weight:800;color:var(--azul);line-height:1.3;}
  .menu-card p{font-size:0.75rem;color:#7a8fa6;line-height:1.5;}
  .card-btn{background:var(--azul);color:white;font-family:'Montserrat',sans-serif;font-size:0.72rem;font-weight:700;padding:6px 14px;border-radius:20px;margin-top:4px;transition:background 0.15s;}
  .menu-card:hover .card-btn{background:var(--azul-claro);}
  .footer-info{margin-top:36px;text-align:center;font-size:0.76rem;color:#8a9ab5;position:relative;z-index:1;animation:fadeUp 0.55s 0.5s ease both;}
  .footer-info strong{color:var(--azul);font-family:'Montserrat',sans-serif;}
  #viewer{display:none;flex-direction:column;height:100vh;position:fixed;inset:0;z-index:100;background:white;}
  #viewer.active{display:flex;}
  .viewer-topbar{background:linear-gradient(90deg,var(--azul) 0%,var(--azul-medio) 100%);padding:10px 18px;display:flex;align-items:center;gap:12px;box-shadow:0 2px 12px rgba(0,0,0,0.2);flex-shrink:0;}
  .viewer-logo{background:white;border-radius:8px;padding:4px 8px;display:flex;align-items:center;flex-shrink:0;}
  .viewer-logo img{height:32px;display:block;}
  .btn-voltar{background:rgba(255,255,255,0.15);border:1px solid rgba(255,255,255,0.25);color:white;border-radius:8px;padding:7px 14px;font-family:'Montserrat',sans-serif;font-size:0.78rem;font-weight:700;cursor:pointer;display:flex;align-items:center;gap:5px;transition:background 0.15s;white-space:nowrap;flex-shrink:0;}
  .btn-voltar:hover{background:rgba(255,255,255,0.25);}
  .viewer-title{font-family:'Montserrat',sans-serif;font-size:0.85rem;font-weight:700;color:white;flex:1;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;}
  .viewer-badge{background:var(--laranja);color:white;font-family:'Montserrat',sans-serif;font-size:0.65rem;font-weight:700;padding:4px 10px;border-radius:50px;text-transform:uppercase;letter-spacing:0.8px;flex-shrink:0;}
  #frame-wrap{flex:1;overflow:hidden;}
  #frame-wrap iframe{width:100%;height:100%;border:none;display:block;}
  @media(max-width:1000px){.menu-grid{grid-template-columns:repeat(3,1fr);max-width:720px;}} @media(max-width:660px){.menu-grid{grid-template-columns:repeat(2,1fr);max-width:480px;}.hero h1{font-size:1.6rem;}.hero-card{flex-direction:column;}.hero-card-right{min-height:auto;padding:12px 16px;}}
  @media(max-width:500px){.menu-grid{grid-template-columns:1fr;max-width:340px;}}
</style>
</head>
<body>
<div id="home">
  <div class="hero">
    <div class="hero-card">
      <div class="hero-card-left"><img src="data:image/png;base64," alt="Everton Francisco"></div>
      <div class="hero-card-right">
        <div class="contact-item">&#128241; (51) 99454.9478</div>
        <div class="contact-item">&#9993; contato@evertonfrancisco.com.br</div>
        <div class="contact-item">&#128205; Av. Dorival C. L. de Oliveira, 5285 &ndash; Gravataí/RS</div>
      </div>
    </div>
    <h1>Olá, somos a<br><span class="destaque">Everton Francisco</span><br>correspondente bancário.</h1>
    <p>Qual é o modelo de declaração que você deseja?</p>
  </div>
  <div class="menu-grid">
    <div class="menu-card" onclick="openTool('carta','Carta de Cancelamento')">
      <div class="card-icon">&#128196;</div><h3>Carta de Cancelamento</h3><p>Autorização de cancelamento de avaliações junto à CEF</p><span class="card-btn">Acessar &rarr;</span>
    </div>
    <div class="menu-card" onclick="openTool('fator','Declaração de Fator Social')">
      <div class="card-icon">&#127968;</div><h3>Declaração de Fator Social</h3><p>Declaração para uso do fator social no financiamento</p><span class="card-btn">Acessar &rarr;</span>
    </div>
    <div class="menu-card" onclick="openTool('renda','Carta de Descontinuidade')">
      <div class="card-icon">&#128203;</div><h3>Decl. de Renda Descontinuada</h3><p>Declaração de renda descontinuada para análise de crédito</p><span class="card-btn">Acessar &rarr;</span>
    </div>
    <div class="menu-card" onclick="openTool('cotista','Calculadora de Cotista')">
      <div class="card-icon laranja">&#129518;</div><h3>Calculadora de Cotista</h3><p>Calcule o tempo de contribuição como cotista do FGTS</p><span class="card-btn">Acessar &rarr;</span>
    </div>
    <div class="menu-card" onclick="openTool('informal','Ficha de Renda Informal')">
      <div class="card-icon laranja">&#128203;</div><h3>Ficha de Renda Informal</h3><p>Complementação de dados para análise de renda informal</p><span class="card-btn">Acessar &rarr;</span>
    </div>
  </div>
  <div class="footer-info"><strong>Everton Francisco Financiamentos Habitacionais</strong> &middot; evertoncorrespondente</div>
</div>
<div id="viewer">
  <div class="viewer-topbar">
    <div class="viewer-logo"><img src="data:image/png;base64," alt="Everton Francisco"></div>
    <button class="btn-voltar" onclick="closeTool()">&larr; Voltar</button>
    <span class="viewer-title" id="viewer-title">Documento</span>
    <span class="viewer-badge">CEF</span>
  </div>
  <div id="frame-wrap">
    <iframe id="tool-frame" allow="*" title="Documento"></iframe>
  </div>
</div>
<script>
const TOOLS = Object.freeze({
  carta:   ``,
  fator:   ``,
  renda:   ``,
  informal: ``,
  cotista: ``
});
let _blobUrl = null;
function b64ToBlob(b64) {
  const bin = atob(b64);
  const buf = new Uint8Array(bin.length);
  for (let i = 0; i < bin.length; i++) buf[i] = bin.charCodeAt(i);
  return new Blob([buf], {type: 'text/html; charset=utf-8'});
}
function openTool(name, title) {
  if (_blobUrl) { URL.revokeObjectURL(_blobUrl); _blobUrl = null; }
  _blobUrl = URL.createObjectURL(b64ToBlob(TOOLS[name]));
  document.getElementById('viewer-title').textContent = title;
  document.getElementById('tool-frame').src = _blobUrl;
  document.getElementById('viewer').classList.add('active');
  document.getElementById('home').style.display = 'none';
  document.body.style.overflow = 'hidden';
}
function closeTool() {
  document.getElementById('viewer').classList.remove('active');
  document.getElementById('home').style.display = '';
  document.getElementById('tool-frame').src = '';
  document.body.style.overflow = '';
  if (_blobUrl) { URL.revokeObjectURL(_blobUrl); _blobUrl = null; }
}
</script>
</body>
</html>
